# jawatch — Production (Vercel)
# Set all vars below in Vercel dashboard: Project Settings → Environment Variables

# API base URL — avicenna on VPS behind Caddy (exposed to browser)
NEXT_PUBLIC_API_URL=https://api.dwizzy.my.id/v1

# Internal API URL — used by Server Components / API routes (not exposed to browser)
# Points to same avicenna instance; Vercel's edge resolves this via public DNS
INTERNAL_API_URL=https://api.dwizzy.my.id/v1