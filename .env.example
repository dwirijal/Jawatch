# jawatch env
# Server-only media API config. Do not prefix with NEXT_PUBLIC_*.
JAWATCH_MEDIA_API_URL=https://media-source.example
JAWATCH_MEDIA_API_TIMEOUT_MS=8000
SITE_URL=http://localhost:3000
# Deprecated compatibility fallback; prefer SITE_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics/ads — public client IDs (safe to expose). Component renders nothing if unset.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GADS_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Support/donate link (Saweria/Trakteer/Ko-fi). Support CTA hides the Dukung button if unset.
# NEXT_PUBLIC_DONATE_URL=https://trakteer.id/xxxx

# Auth (better-auth). Server-only.
BETTER_AUTH_SECRET=change-me-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
# Extra trusted origins (comma-separated) for LAN/staging access, e.g. accessing the dev
# server via device IP. baseURL above is always trusted; add others here to avoid 403 "Invalid origin".
# BETTER_AUTH_TRUSTED_ORIGINS=http://192.168.100.6:3001,http://localhost:3001
# Google OAuth (optional; both required to enable the Google button).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
